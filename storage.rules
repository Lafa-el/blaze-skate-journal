rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /avatars/{athleteId}/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.uid == athleteId;
    }

    match /users/{athleteId}/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.uid == athleteId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
